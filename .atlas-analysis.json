  "keyFeatures": [
    "Role-based access control with four roles: Coordinador, Prensa, Gestión Humana, and Administrador",
    "Biweekly report submission by coordinators with Google Drive file storage",
    "HR report review and approval workflow",
    "News publishing and management with visibility control",
    "Institutional document/format library with public download access",
    "Admin user management and system metrics dashboard",
    "JWT-based authentication stored in localStorage",
    "NeonDB (serverless PostgreSQL) for all persistent data",
    "Public-facing landing page with news and downloadable formats",
    "Responsive dashboard with collapsible sidebar navigation"
  ],
